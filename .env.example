# Hugging Face token (needed to download gated models like LLaMA)
HF_TOKEN=hf_your_token_here

# Model to evaluate (change this to swap models)
MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Device: cuda, cpu, or mps (Apple Silicon)
DEVICE=cuda

# Batch size for lm-eval (reduce if OOM)
BATCH_SIZE=8

# Where to save results
RESULTS_DIR=./results
